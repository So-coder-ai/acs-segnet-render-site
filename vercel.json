{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python vercel_build.py",
  "functions": {
    "app.py": {
      "maxDuration": 300,
      "includeFiles": [
        "templates/**",
        "static/**",
        "checkpoints/ACSSegNet_fold1_best.pth",
        "ACS-SegNet/**"
      ],
      "excludeFiles": "{checkpoints/ACSSegNet_fold0_best.pth,checkpoints/ACSSegNet_fold2_best.pth,static/results/**,__pycache__/**,**/*.pyc,.venv/**}"
    }
  }
}
